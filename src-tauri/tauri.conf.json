{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "friendolls-desktop",
  "version": "0.1.0",
  "identifier": "com.adamcv.friendolls-desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:2750",
    "beforeBuildCommand": "pnpm build",
