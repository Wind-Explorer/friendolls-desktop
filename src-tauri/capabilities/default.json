{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "scene", "app_menu", "doll_editor*"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:window:allow-close",
    "process:default"
  ]
}
